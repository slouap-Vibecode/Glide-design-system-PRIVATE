{
    "id": "backstop_banner",
    "viewports": [
        {
            "label": "phone",
            "width": 320,
            "height": 2237
        },
        {
            "label": "tablet",
            "width": 1024,
            "height": 1409
        },
        {
            "label": "desktop",
            "width": 1920,
            "height": 1337
        }
    ],
    "onBeforeScript": "puppet/onBefore.js",
    "onReadyScript": "puppet/onReady.js",
    "paths": {
        "bitmaps_reference": "backstop_data/bitmaps_reference",
        "bitmaps_test": "backstop_data/bitmaps_test",
        "engine_scripts": "backstop_data/engine_scripts",
        "html_report": "backstop_data/html_report",
        "ci_report": "backstop_data/ci_report"
    },
    "report": [
        "CI"
    ],
    "engine": "puppeteer",
    "engineOptions": {
        "args": [
            "--no-sandbox",
            "--disable-setuid-sandbox",
            "--disable-dev-shm-usage",
            "--disable-accelerated-2d-canvas",
            "--no-first-run",
            "--no-zygote",
            "--disable-gpu"
        ],
        "protocolTimeout": 960000
    },
    "asyncCaptureLimit": 3,
    "asyncCompareLimit": 50,
    "debug": false,
    "debugWindow": false,
    "scenarios": [
        {
            "label": "1. DISPLAY all banners",
            "url": "http://localhost:8080/#/banner",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "verify the display of all the banners"
        },
        {
            "label": "2. CLICK on TC1 dismiss cross",
            "url": "http://localhost:8080/#/banner",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "click on the dismiss cross of the TC1",
            "clickSelector": "[data-test-case=\"1\"] .nck-banner-dismiss",
            "selectors": [
                "[data-test-case=\"1\"]"
            ]
        },
        {
            "label": "2.1 CLICK on TC8 dismiss cross of banner without radius",
            "url": "http://localhost:8080/#/banner",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "click on the dismiss cross of the TC8",
            "clickSelector": "[data-test-case=\"8\"] .nck-banner-dismiss",
            "selectors": [
                "[data-test-case=\"8\"]"
            ]
        },
        {
            "label": "3. CLICK on TC6 heading item link-button",
            "url": "http://localhost:8080/#/banner",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "click on TC6 heading item link(aria role:button)",
            "clickSelector": "[data-test-case=\"6\"] .nck-banner .nck-banner-heading .nck-link",
            "selectors": [
                "[data-test-case=\"6\"]"
            ]
        },
        {
            "label": "3.1 CLICK on TC5 heading item link",
            "url": "http://localhost:8080/#/banner",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "click on TC5 heading item link(aria role:link)",
            "clickSelector": "[data-test-case=\"5\"] .nck-banner .nck-banner-heading .nck-link",
            "selectors": [
                "[data-test-case=\"5\"]"
            ]
        },
        {
            "label": "3.2 CLICK on TC6 body item link",
            "url": "http://localhost:8080/#/banner",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "click TC6 body item link(aria role:link)",
            "clickSelector": "[data-test-case=\"6\"] .nck-banner .nck-banner-list .nck-link",
            "selectors": [
                "[data-test-case=\"6\"]"
