    "report": [
        "CI"
    ],
    "engine": "puppeteer",
    "engineOptions": {
        "args": [
    "--no-sandbox",
    "--disable-setuid-sandbox",
    "--disable-dev-shm-usage",
    "--disable-accelerated-2d-canvas",
    "--no-first-run",
    "--no-zygote",

    "--disable-gpu"
  ],
        "ignoreDefaultArgs": [
            "--hide-scrollbars"
        ],
        "protocolTimeout": 960000
    },
    "asyncCaptureLimit": 3,
    "asyncCompareLimit": 50,
    "debug": false,
    "debugWindow": false,
