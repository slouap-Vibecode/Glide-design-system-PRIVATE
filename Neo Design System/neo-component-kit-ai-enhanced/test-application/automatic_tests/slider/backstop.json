            "requireSameDimensions": true,
            "description": "Focus on the slider of TC1 then press right arrow key",
            "selectors": "[data-test-case=\"1\"]",
            "onReadyScript": "puppet/actions.js",
            "actions": [
                {
                    "type": "focus",
                    "selector": "[data-test-case=\"1\"] .noUi-handle"
                },
                {
                    "type": "pressKey",
                    "key": "ArrowRight"
