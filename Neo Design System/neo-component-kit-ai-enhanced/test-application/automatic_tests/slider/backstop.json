{
    "id": "backstop_slider",
    "viewports": [
        {
            "label": "phone",
            "width": 320,
            "height": 1150
        },
        {
            "label": "tablet",
            "width": 1024,
            "height": 1030
        },
        {
            "label": "desktop",
            "width": 1920,
            "height": 950
        }
    ],
    "onBeforeScript": "puppet/onBefore.js",
    "onReadyScript": "puppet/onReady.js",
    "scenarios": [
        {
            "label": "1. NCK slider - default display of the page",
            "url": "http://localhost:8080/#/slider",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "display the default state of all the sliders on the page"
        },
        {
            "label": "2.1 NCK slider - CLICK TC1 slider thumb",
            "url": "http://localhost:8080/#/slider",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "Click on the slider thumb of TC1",
            "onReadyScript": "puppet/actions.js",
            "actions": [
                {
                    "type": "click",
                    "selector": "[data-test-case=\"1\"] .noUi-handle"
                },
                {
                    "type": "mouseMove",
                    "coordinate": {
                        "x": 5,
                        "y": 5
                    }
                }
            ],
            "selectors": "[data-test-case=\"1\"]"
        },
        {
            "label": "2.2 NCK slider - CLICK TC2 slider thumb",
            "url": "http://localhost:8080/#/slider",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "Click on the slider thumb of TC2",
            "onReadyScript": "puppet/actions.js",
            "actions": [
                {
                    "type": "click",
                    "selector": "[data-test-case=\"2\"] .noUi-handle"
                },
                {
                    "type": "mouseMove",
                    "coordinate": {
                        "x": 5,
                        "y": 5
                    }
                }
            ],
            "selectors": "[data-test-case=\"2\"]"
        },
        {
            "label": "2.3 NCK slider - CLICK TC1 slider bar",
            "url": "http://localhost:8080/#/slider",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "Click on the slider bar of TC1",
            "onReadyScript": "puppet/actions.js",
            "actions": [
                {
                    "type": "click",
                    "selector": "[data-test-case=\"1\"] .nck-slider-inner"
                },
                {
                    "type": "mouseMove",
                    "coordinate": {
                        "x": 5,
                        "y": 5
                    }
                }
            ],
            "selectors": "[data-test-case=\"1\"]"
        },
        {
            "label": "3.1 NCK slider - HOVER TC1 slider thumb",
            "url": "http://localhost:8080/#/slider",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "Hover on the slider of TC1",
            "hoverSelector": "[data-test-case=\"1\"] .noUi-handle",
            "selectors": "[data-test-case=\"1\"]"
        },
        {
            "label": "3.2 NCK slider - HOVER+MOUSE DOWN TC1 slider thumb",
            "url": "http://localhost:8080/#/slider",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "Hover and Mouse down on the slider of TC1",
            "onReadyScript": "hoverAndPressMouseSelector.js",
            "hoverAndPressMouseSelector": "[data-test-case=\"1\"] .noUi-handle",
            "selectors": "[data-test-case=\"1\"]"
        },
        {
            "label": "3.3 NCK slider - HOVER+MOUSE DOWN TC2 slider thumb",
            "url": "http://localhost:8080/#/slider",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "Hover and Mouse down on the slider of TC2",
            "onReadyScript": "hoverAndPressMouseSelector.js",
            "hoverAndPressMouseSelector": "[data-test-case=\"2\"] .noUi-handle",
            "selectors": "[data-test-case=\"2\"]"
        },
        {
            "label": "3.4 NCK slider - Click and drag TC1 slider thumb to the right",
            "url": "http://localhost:8080/#/slider",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "Click and drag TC1 slider thumb to the right",
            "onReadyScript": "moveMouseWhileHolding.js",
            "hoverSelector": "[data-test-case=\"1\"] .noUi-handle",
            "xPixelToMove": 30,
            "selectors": "[data-test-case=\"1\"]"
        },
        {
            "label": "3.5 NCK slider - Click and drag TC2 slider thumb to the left",
            "url": "http://localhost:8080/#/slider",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "Click and drag TC2 slider thumb to the right",
            "onReadyScript": "moveMouseWhileHolding.js",
            "hoverSelector": "[data-test-case=\"2\"] .noUi-handle",
            "xPixelToMove": -10,
            "selectors": "[data-test-case=\"2\"]"
        },
        {
            "label": "4.1 NCK slider - FOCUS TC1 slider thumb",
            "url": "http://localhost:8080/#/slider",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
            "description": "Focus on the slider of TC1",
            "onReadyScript": "focus.js",
            "focusSelector": "[data-test-case=\"1\"] .noUi-handle",
            "selectors": "[data-test-case=\"1\"]"
        },
        {
            "label": "4.2 NCK slider - FOCUS TC2 slider thumb",
            "url": "http://localhost:8080/#/slider",
            "misMatchThreshold": 0,
            "requireSameDimensions": true,
